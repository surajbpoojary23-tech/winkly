BOT_TOKEN=replace_with_telegram_bot_token
BOT_USERNAME=Winkly_dating_bot

REDIS_URL=rediss://default:replace_with_redis_token@your-upstash-host.upstash.io:6379
PORT=8080
WEBHOOK_URL=https://your-service.onrender.com
TELEGRAM_WEBHOOK_PATH=/telegram/webhook
# Optional. If omitted, the bot derives a stable webhook secret from BOT_TOKEN.
TELEGRAM_WEBHOOK_SECRET=replace_with_random_32_plus_char_secret
# Only set true for local single-instance polling, never for Render web services.
ALLOW_LONG_POLLING=false

# Razorpay Payment Gateway
RAZORPAY_KEY_ID=rzp_live_or_test_key_id
RAZORPAY_KEY_SECRET=replace_with_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=replace_with_razorpay_webhook_secret
